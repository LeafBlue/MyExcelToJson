  <property name="styleSheet">
   <string notr="true">/* 全局设置 */
QWidget {
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, sans-serif;
    font-size: 12px;
    color: #333333;
}

/* 主窗口背景 */
QMainWindow, QWidget#centralwidget {
    background-color: #F5F7FA; /* 浅灰蓝背景 */
}

/* 标签样式 (选择excel, 选择sheet) */
QLabel {
    font-weight: bold;
    color: #606266;
    padding: 5px;
}

/* 输入框样式 (文件路径) */
QLineEdit#lineEdit_filePath {
    background-color: #FFFFFF;
    border: 1px solid #DCDFE6;
    border-radius: 4px;
    padding: 6px 10px;
    selection-background-color: #409EFF;
}
QLineEdit#lineEdit_filePath:focus {
    border: 1px solid #409EFF;
    outline: none;
}

/* 下拉框样式 (选择sheet) */
QComboBox#comboBox {
    background-color: #FFFFFF;
    border: 1px solid #DCDFE6;
    border-radius: 4px;
    padding: 5px 10px;
    min-width: 120px;
}
QComboBox#comboBox:focus {
    border: 1px solid #409EFF;
}
QComboBox#comboBox::drop-down {
    border: none;
    width: 20px;
}
QComboBox#comboBox::down-arrow {
    image: none; /* 隐藏默认箭头，或者你可以放一个图标 */
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #C0C4CC;
    margin-right: 8px;
}

/* 按钮通用样式 */
QPushButton {
    background-color: #FFFFFF;
    border: 1px solid #DCDFE6;
    border-radius: 4px;
    padding: 6px 15px;
    font-weight: bold;
    color: #606266;
}
QPushButton:hover {
    color: #409EFF;
    border-color: #C6E2FF;
    background-color: #ECF5FF;
}
QPushButton:pressed {
    background-color: #409EFF;
    color: white;
    border-color: #409EFF;
}

/* 特定按钮样式：如果是主要操作按钮（比如“解析”），可以单独加强 */
QPushButton#pushButton_2 { 
    /* 这里假设 pushButton_2 是“解析”按钮，给它一个主色调 */
    background-color: #409EFF;
    color: white;
    border: 1px solid #409EFF;
}
QPushButton#pushButton_2:hover {
    background-color: #66B1FF;
    border-color: #66B1FF;
    color: white;
}
QPushButton#pushButton_2:pressed {
    background-color: #3A8EE6;
}</string>
